# QueryLake local development environment template
#
# Copy to `.env` and adjust for your environment.
# Most local dev defaults work without additional changes.

# Recommended: set a stable secret for OAuth/session signing in local dev.
QUERYLAKE_OAUTH_SECRET_KEY=change-me-local-secret

# Optional runtime controls
QUERYLAKE_DB_CONNECT_TIMEOUT=5
# QUERYLAKE_REDIS_URL=redis://localhost:6379/0

# Optional lexical retrieval rollout controls
# Broad chunk-lane default candidate from the BM25 lexical tranche.
QUERYLAKE_LEXICAL_VARIANT_ID_SEARCH_BM25_DOCUMENT_CHUNK=QL-L3
QUERYLAKE_LEXICAL_VARIANT_ID_SEARCH_HYBRID_DOCUMENT_CHUNK=QL-L3
# Route-specific exactness extension for document/title/id-sensitive lookup.
QUERYLAKE_LEXICAL_VARIANT_ID_SEARCH_BM25_DOCUMENT=QL-L4
